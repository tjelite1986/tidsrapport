# Kopiera den här filen till .env och fyll i värdena
# cp .env.example .env

# Obligatoriskt – generera med: openssl rand -base64 32
NEXTAUTH_SECRET=

# Appens URL (utan avslutande slash)
# Enkel setup:  http://localhost:3000
# Traefik/HTTPS: https://tidrapport.example.com
NEXTAUTH_URL=http://localhost:3000

# Valfritt – krävs bara för AI-bildanalys av schema (Inställningar -> Importera schema)
ANTHROPIC_API_KEY=

# Används bara med docker-compose.traefik.yml
# Domännamn som Traefik lyssnar på, t.ex. tidrapport.example.com
DOMAIN=tidrapport.example.com

# Traefik certresolver-namn (t.ex. cloudflare, letsencrypt)
CERT_RESOLVER=letsencrypt
